{
  "expo": {
    "name": "MusicID",
    "slug": "songidentifier",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/shazam.png",
    "scheme": "donmoviestream",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/shazam.png",
        "backgroundImage": "./assets/images/shazam.png",
        "monochromeImage": "./assets/images/shazam.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-light.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "image": "./assets/images/splash-dark.png",
            "imageWidth": 200,
            "contentFit": "contain",
            "backgroundColor": "#473cd9"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    }
  }
}
